# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── App URL (used in webhook callback_url) ──────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Ollama (local LLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Whisper (speech-to-text) ────────────────────────────────────────────────
# Endpoint for whisper-asr-webservice compatible server
WHISPER_API_URL=http://localhost:9000

# ─── n8n (workflow automation) ───────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
# Optional API key for n8n authentication
N8N_API_KEY=

# ─── Webhook security ────────────────────────────────────────────────────────
# Shared secret sent by n8n in the x-clavio-secret header.
# Set to a random string (e.g. openssl rand -hex 32).
# Leave empty to disable verification (not recommended in production).
WEBHOOK_SECRET=

# ─── Cobalt (video downloader) ───────────────────────────────────────────────
COBALT_API_URL=http://localhost:9001

# ─── Python (optional override) ──────────────────────────────────────────────
# Path to the Python executable used by Clipify engine and ScrapeGraph.
# Defaults to lib/python_env/bin/python3 (or system python3).
PYTHON_PATH=
